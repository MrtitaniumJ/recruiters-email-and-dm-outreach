# Copy to .env in this folder. Root .env is also loaded for missing keys (e.g. NOTION_TOKEN).

# LinkedIn session cookie (keep private)
LI_AT=

# Optional: override root .env
NOTION_TOKEN=
LINKEDIN_NOTION_DB_ID=
LINKEDIN_NOTION_PARENT_PAGE_ID=
LINKEDIN_NOTION_SEED_DATABASE_ID=

HEADLESS=false
NAVIGATION_TIMEOUT_MS=45000

# LinkedIn connections fetch (cold-dm-outreach/fetchConnections.js)
# FETCH_MODE=latest — stop when no profiles missing from Notion appear for a streak (daily runs).
# FETCH_MODE=full — backfill toward full LinkedIn count (slow; set once until Notion catches up).
# FETCH_MODE=latest
# FETCH_MAX_SCROLL_STEPS=800
# FETCH_STAGNATION_LIMIT=15
# FETCH_LATEST_HEAD_STEPS=12
# FETCH_SCROLLS_PER_EXTRACT=2
# FETCH_MAX_COMPOSE_ANCHORS=0
#   (optional cap, e.g. 450, trims DOM work per extract: head+tail of compose links; 0 = unlimited)
# PUPPETEER_PROTOCOL_TIMEOUT_MS=600000
#   (CDP ms; 0 = no timeout)

# Outreach tuning (defaults shown in code; uncomment to override)
# DRY_RUN=false
# OUTREACH_DAILY_CAP=30
# OUTREACH_MIN_DELAY_MS=60000
# OUTREACH_MAX_DELAY_MS=150000
